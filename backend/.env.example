DATABASE_URL=postgresql://user:password@localhost:5432/carbon_footprint
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional: regex for local dev (localhost/127.0.0.1/LAN on any port). Leave empty in production.
CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}):\d+
